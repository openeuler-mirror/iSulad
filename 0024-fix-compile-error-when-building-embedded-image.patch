     ${ISULA_LIBUTILS_LIBRARY}
-    ${LIBARCHIVE_LIBRARY}
     ${LIBTAR_LIBRARY}
-    ${WEBSOCKET_LIBRARY}
     ${CRYPTO_LIBRARY}
    )
 
+if (ENABLE_OCI_IMAGE)
+    target_link_libraries(libisula ${LIBARCHIVE_LIBRARY} ${WEBSOCKET_LIBRARY})
+endif()
+
+if (ENABLE_SELINUX)
+    target_link_libraries(libisula ${SELINUX_LIBRARY})
