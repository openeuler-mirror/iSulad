     }
+    auto token = UniqueToken();
+    CacheEntry tmp;
+    tmp.SetValue(token, &req, nullptr, std::chrono::system_clock::now() + std::chrono::minutes(1));
+    m_ll.push_front(tmp);
+    m_tokens.insert(std::make_pair(token, tmp));
