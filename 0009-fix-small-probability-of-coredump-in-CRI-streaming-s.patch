     GarbageCollection();
@@ -56,7 +70,8 @@ std::string RequestCache::Insert(::google::protobuf::Message *req)
         return "";
     }
     auto token = UniqueToken();
-    CacheEntry tmp { token, req, std::chrono::system_clock::now() + std::chrono::minutes(1) };
+    CacheEntry tmp;
