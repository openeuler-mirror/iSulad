+static int get_cgroup_version()
+{
+    struct statfs fs = {0};
+
+    if (statfs(CGROUP_MOUNTPOINT, &fs) != 0) {
+        ERROR("failed to statfs %s: %s", CGROUP_MOUNTPOINT, strerror(errno));
+        return -1;
+    }
+
+    if (fs.f_type == CGROUP2_SUPER_MAGIC) {
+        return CGROUP_VERSION_2;
+    } else {
+        return CGROUP_VERSION_1;
+    }
+}
