+static ssize_t archive_context_read(void *context, void *buf, size_t len)
+{
+    struct archive_context *ctx = (struct archive_context *)context;
+    if (ctx == NULL) {
+        return -1;
+    }
+    if (ctx->stdout_fd >= 0) {
+        return util_read_nointr(ctx->stdout_fd, buf, len);
+    }
+    return 0;
