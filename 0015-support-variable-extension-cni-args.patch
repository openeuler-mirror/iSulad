+    for (const auto &work : cniArgs) {
+        rt->args[workLen][0] = util_strdup_s(work.first.c_str());
+        rt->args[workLen][1] = util_strdup_s(work.second.c_str());
+        workLen++;
     }
 
     *cni_rc = rt;
-    return;
