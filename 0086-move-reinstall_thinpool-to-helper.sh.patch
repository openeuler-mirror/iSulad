-function reinstall_thinpool()
-{
-    dev_disk=`pvs | grep isulad | awk '{print$1}'`
-    rm -rf /var/lib/isulad/*
-    dmsetup remove_all
-    lvremove -f isulad/thinpool
-    lvremove -f isulad/thinpoolmeta
-    vgremove -f isulad
