-    fi
-    touch /etc/lvm/profile/isulad-thinpool.profile
-    cat > /etc/lvm/profile/isulad-thinpool.profile <<EOF
-activation {
-thin_pool_autoextend_threshold=80
-thin_pool_autoextend_percent=20
