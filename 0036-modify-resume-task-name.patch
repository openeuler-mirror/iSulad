         goto cleanup;
     }
@@ -1070,7 +1075,7 @@ int dev_create_snap_device_raw(const char *pool_name, int device_id, int base_de
             ret = ERR_DEVICE_ID_EXISTS;
             goto cleanup;
         }
-        ERROR("devicemapper: Error running deviceCreate (CreateSnapDeviceRaw)");
