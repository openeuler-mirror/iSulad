         ret = -1;
         goto out;
@@ -2577,7 +2585,8 @@ static int determine_driver_capabilities(const char *version, struct device_set
         goto out;
     }
 
-    if (util_parse_byte_size_string(tmp_str[1], &minor) != 0) {
+    ret = util_parse_byte_size_string(tmp_str[1], &minor);
+    if (ret != 0) {
