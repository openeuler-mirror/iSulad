-        ERROR("devicemapper: Error running deviceResume %d", ret);
-        ret = -1;
+        ERROR("devicemapper: run task of DM_DEVICE_RESUME failed");
     }
 
     DEBUG("Start udev wait on resume device");
@@ -837,7 +842,6 @@ out:
